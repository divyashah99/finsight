# ─── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Market data ────────────────────────────────────────────────────────────
# Free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=demo
# Free tier: 25 req/day, 5 req/min
ALPHAVANTAGE_RATE_PER_MIN=5
ALPHAVANTAGE_RATE_PER_DAY=25

# ─── Storage ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finsight:finsight@localhost:5432/finsight
DATABASE_URL_SYNC=postgresql://finsight:finsight@localhost:5432/finsight

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sec_filings

# ─── SEC ────────────────────────────────────────────────────────────────────
# EDGAR requires a User-Agent identifying you. Replace with your name + email.
SEC_USER_AGENT=FinSight Research contact@example.com

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=local
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
